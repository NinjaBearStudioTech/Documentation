<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE labels SYSTEM "https://resources.jetbrains.com/writerside/1.0/labels-list.dtd">
<labels xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://resources.jetbrains.com/writerside/1.0/labels.xsd">

    <primary-label id="bot" short-name="BOT" name="Bot">Ninja Bot</primary-label>
    <primary-label id="combat" short-name="CBT" name="Combat">Ninja Combat</primary-label>
    <primary-label id="factions" short-name="FCT" name="Factions">Ninja Factions</primary-label>
    <primary-label id="gas" short-name="GAS" name="G.A.S.">Ninja GAS</primary-label>
    <primary-label id="input" short-name="IPT" name="Input">Ninja Input</primary-label>
    <primary-label id="integrations" name="ITG" short-name="Integrations">Integrations</primary-label>
    <primary-label id="interaction" name="INT" short-name="Interaction">Ninja Interaction</primary-label>
    <primary-label id="inventory" short-name="INV" name="Inventory">Ninja Inventory</primary-label>
    <primary-label id="tokens" short-name="TKN" name="Tokens">Ninja Tokens</primary-label>

    <secondary-label id="wip" name="work-in-progress" color="strawberry">Work in progress, informational only.</secondary-label>
    <secondary-label id="experimental" name="experimental" color="strawberry">Subject to changes, might have bugs.</secondary-label>
    <secondary-label id="beta" name="beta" color="strawberry">Stable API, but you might find bugs.</secondary-label>
    <secondary-label id="advanced" name="advanced" color="tangerine">Advanced feature, some experience required.</secondary-label>
    <secondary-label id="guide" name="guide" color="blue">A step-by-step guide, with a specific goal.</secondary-label>
    <secondary-label id="optional" name="optional" color="purple">An optional step, used to achieve specific goals.</secondary-label>
    <secondary-label id="recommended" name="recommended" color="purple">Enforces that an optional step is still recommended for most cases.</secondary-label>
    <secondary-label id="bot-sec" name="Bot" color="green">Ninja Bot</secondary-label>
    <secondary-label id="combat-sec" name="Combat" color="green">Ninja Combat</secondary-label>
    <secondary-label id="factions-sec" name="Factions" color="green">Ninja Factions</secondary-label>
    <secondary-label id="gas-sec" name="G.A.S." color="green">Ninja GAS</secondary-label>
    <secondary-label id="input-sec" name="Input" color="green">Ninja Input</secondary-label>
    <secondary-label id="interaction-sec" name="Interaction" color="green">Ninja Interaction</secondary-label>
    <secondary-label id="inventory-sec" name="Inventory" color="green">Ninja Inventory</secondary-label>
    
</labels>